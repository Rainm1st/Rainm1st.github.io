  "exercises": [
    {
      "id": "seated_chest_press",
      "name": "坐姿推胸机 Seated chest press",
      "group": "chest",
      "secondary": ["pectoralis_major", "anterior_deltoid"],
      "type": "fixed",
      "movement": ["push"],
      "focus": "胸大肌为主，前三角和肱三头协同",
      "ins": "调整座椅，使把手与中胸平齐；背部贴靠垫，双脚踩稳；向前推至手臂接近伸直但不要锁死肘部；缓慢回程。",
      "beginnerPlan": "2-3组 x 10-12次，RPE 6-7",
      "advancedPlan": "4组 x 6-10次，RPE 7-9"
    },
    {
      "id": "lat_pulldown",
      "name": "高位下拉机 Lat pulldown",
      "group": "back",
      "secondary": ["latissimus_dorsi", "trapezius"],
      "type": "fixed",
      "movement": ["pull"],
      "focus": "主打背阔肌与上背部",
      "ins": "固定大腿压垫，握杠略宽于肩；先沉肩，再下拉到上胸附近；避免耸肩与后仰借力；缓慢回顶。",
      "beginnerPlan": "2-3组 x 10-12次，RPE 6-7",
      "advancedPlan": "4组 x 6-10次，RPE 7-9"
    },
    {
      "id": "seated_row",
      "name": "坐姿划船机 Seated row",
      "group": "back",
      "secondary": ["latissimus_dorsi", "rhomboids", "trapezius"],
      "type": "fixed",
      "movement": ["pull"],
      "focus": "主打背阔肌、菱形肌、中下斜方肌",
      "ins": "调座椅让把手与肩同高；先稳定躯干，再拉向腹部/下胸；肩胛后缩，回程慢放。",
      "beginnerPlan": "2-3组 x 10-12次，RPE 6-7",
      "advancedPlan": "4组 x 8-12次，RPE 7-9"
    },
    {
      "id": "high_row",
      "name": "高位划船机 High row",
      "group": "back",
      "secondary": ["rhomboids", "posterior_deltoid", "trapezius"],
      "type": "fixed",
      "movement": ["pull"],
      "focus": "偏上背厚度、后三角和菱形肌",
      "ins": "握宽把，胸部抬起；肘部向后外侧带动，把手拉向上胸；顶点短停后控制回程。",
      "beginnerPlan": "2-3组 x 10次，RPE 6-7",
      "advancedPlan": "4组 x 8-12次，RPE 7-9"
    },
    {
      "id": "assisted_pullup",
      "name": "辅助引体向上机 Assisted pull-up machine",
      "group": "back",
      "secondary": ["latissimus_dorsi", "teres_major"],
      "type": "assist",
      "movement": ["pull"],
      "focus": "背阔肌和整体拉力能力入门",
      "ins": "选择辅助重量后跪/踩平台，核心收紧，胸部上提，肘向下向后发力；回程控制速度。",
      "beginnerPlan": "2-3组 x 6-10次，RPE 6-7",
      "advancedPlan": "4组 x 8-12次，RPE 7-9"
    },
    {
      "id": "face_pull",
      "name": "绳索面拉 Face pull",
      "group": "shoulders",
      "secondary": ["posterior_deltoid", "infraspinatus", "teres_minor"],
      "type": "cable",
      "movement": ["pull"],
      "focus": "后三角和肩袖稳定",
      "ins": "绳索高度到面部，向额头/鼻梁方向拉；肘自然外展；肩胛后缩，回程保持张力。",
      "beginnerPlan": "2组 x 12-15次，RPE 6-7",
      "advancedPlan": "3-4组 x 12-15次，RPE 7-8"
    },
    {
      "id": "leg_press",
      "name": "坐姿腿举机 Leg press",
      "group": "legs_glutes",
      "secondary": ["quadriceps", "hamstrings", "glute_max"],
      "type": "fixed",
      "movement": ["knee_extend", "hip_extend"],
      "focus": "脚位高偏臀腿后，脚位低偏股四头",
      "ins": "背部尾骨贴实靠垫，双脚与肩同宽；屈膝约90度起始；蹬伸接近伸直但不锁膝；缓慢回程。",
      "beginnerPlan": "2-3组 x 10-12次，RPE 6-7",
      "advancedPlan": "4组 x 8-12次，RPE 7-9"
    },
    {
      "id": "leg_extension",
      "name": "腿屈伸机 Leg extension",
      "group": "legs_glutes",
      "secondary": ["quadriceps"],
      "type": "fixed",
      "movement": ["knee_extend"],
      "focus": "主打股四头肌",
      "ins": "膝关节对准器械转轴，小腿前侧顶住滚垫；伸膝抬起，顶端短停，慢速回放。",
      "beginnerPlan": "2组 x 12次，RPE 6-7",
      "advancedPlan": "4组 x 10-15次，RPE 7-9"
    },
    {
      "id": "leg_curl",
      "name": "腿弯举机 Leg curl",
      "group": "legs_glutes",
      "secondary": ["hamstrings"],
      "type": "fixed",
      "movement": ["knee_flex"],
      "focus": "主打腘绳肌",
      "ins": "膝关节与转轴对齐；脚踝后侧贴滚垫；屈膝拉向臀部，再控制放回。",
      "beginnerPlan": "2组 x 12次，RPE 6-7",
      "advancedPlan": "4组 x 8-12次，RPE 7-9"
    },
    {
      "id": "hip_thrust",
      "name": "臀推机/杠铃臀推 Hip thrust",
      "group": "legs_glutes",
      "secondary": ["glute_max", "hamstrings"],
      "type": "free",
      "movement": ["hip_extend"],
      "focus": "主打臀大肌",
      "ins": "上背支撑稳定，脚掌踩地，膝约90度；向上顶髋，顶点夹臀，避免腰椎过度后仰。",
      "beginnerPlan": "2-3组 x 10次，RPE 6-7",
      "advancedPlan": "4组 x 6-10次，RPE 7-9"
    },
    {
      "id": "hip_abductor",
      "name": "髋外展机 Hip abductor machine",
      "group": "legs_glutes",
      "secondary": ["glute_med", "abductors"],
      "type": "fixed",
      "movement": ["abduction"],
      "focus": "主打臀中肌、臀小肌、外展肌群",
      "ins": "坐稳骨盆，双腿向外打开；动作范围以髋部可控为准；回程慢，不要让配重相撞。",
      "beginnerPlan": "2组 x 12-15次，RPE 6-7",
      "advancedPlan": "4组 x 12-15次，RPE 7-8"
    },
    {
      "id": "hip_adductor",
      "name": "髋内收机 Hip adductor machine",
      "group": "legs_glutes",
      "secondary": ["adductors"],
      "type": "fixed",
      "movement": ["adduction"],
      "focus": "主打内收肌群",
      "ins": "双腿置于外侧挡垫，向中线夹拢；保持上身稳定，慢速回放。",
      "beginnerPlan": "2组 x 12-15次，RPE 6-7",
      "advancedPlan": "4组 x 10-15次，RPE 7-8"
    },
    {
      "id": "biceps_curl_machine",
      "name": "二头弯举机 Biceps curl machine",
      "group": "arms",
      "secondary": ["biceps", "brachialis"],
      "type": "fixed",
      "movement": ["elbow_flex"],
      "focus": "主打肱二头肌与肱肌",
      "ins": "肘关节与器械转轴对齐，上臂贴垫固定；屈肘卷起把手，离心阶段慢放。",
      "beginnerPlan": "2组 x 12次，RPE 6-7",
      "advancedPlan": "4组 x 8-12次，RPE 7-9"
    },
    {
      "id": "triceps_pushdown",
      "name": "三头下压 Triceps pushdown",
      "group": "arms",
      "secondary": ["triceps"],
      "type": "cable",
      "movement": ["elbow_extend"],
      "focus": "主打肱三头肌外侧头和内侧头",
      "ins": "肘贴近身体两侧，向下伸肘压到底；底部停顿后控制回到约90度。",
      "beginnerPlan": "2组 x 12次，RPE 6-7",
      "advancedPlan": "4组 x 8-12次，RPE 7-9"
    },
    {
      "id": "ab_crunch_machine",
      "name": "卷腹机 Abdominal crunch machine",
      "group": "core",
      "secondary": ["rectus_abdominis"],
      "type": "fixed",
      "movement": ["push"],
      "focus": "主打腹直肌",
      "ins": "胸垫贴合上半身，先收紧核心，再向前卷曲躯干；避免只用手臂拉动器械。",
      "beginnerPlan": "2-3组 x 12-15次，RPE 6-7",
      "advancedPlan": "4组 x 10-15次，RPE 7-8"
    },
    {
      "id": "cable_crunch",
      "name": "绳索卷腹 Cable crunch",
      "group": "core",
      "secondary": ["rectus_abdominis", "transversus_abdominis"],
      "type": "cable",
      "movement": ["pull"],
      "focus": "主打腹直肌，可调重量",
      "ins": "高位滑轮绳索置于头侧，保持髋部稳定，通过胸廓向骨盆卷曲完成动作，缓慢回程。",
      "beginnerPlan": "2组 x 12次，RPE 6-7",
      "advancedPlan": "4组 x 10-15次，RPE 7-8"
    }
  ]
}
