        {
            "id": "ex_face_pull",
            "name": "Face Pull",
            "equipment_ids": [
                "eq_cable_station"
            ],
            "primary_muscle_ids": [
                "m_posterior_deltoid"
            ],
            "secondary_muscle_ids": [
                "m_infraspinatus",
                "m_teres_minor"
            ],
            "mechanics": "compound",
            "movement_pattern": [
                "pull"
            ],
            "description": "Targets the posterior deltoids and enhances rotator cuff stability.",
            "instructions": "Set the cable pulley to face level. Pull the rope attachment toward your forehead or the bridge of your nose, allowing the elbows to flare outward. Focus on scapular retraction and external rotation. Maintain tension throughout the return phase.",
            "programming": {
                "beginner": {
                    "sets": "2",
                    "reps": "12-15",
                    "rpe": "6-7"
                },
                "advanced": {
                    "sets": "3-4",
                    "reps": "12-15",
                    "rpe": "7-8"
                }
            }
        },
        {
            "id": "ex_leg_press",
            "name": "Seated Leg Press",
            "equipment_ids": [
                "eq_seated_leg_press"
            ],
            "primary_muscle_ids": [
                "m_quadriceps",
                "m_glute_max"
