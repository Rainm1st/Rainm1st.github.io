            "secondary_muscle_ids": [
                "m_hamstrings"
            ],
            "mechanics": "compound",
            "movement_pattern": [
                "knee_extend",
                "hip_extend"
            ],
            "description": "A higher foot placement emphasizes the glutes and hamstrings, while a lower placement shifts the focus to the quadriceps.",
            "instructions": "Keep your lower back and tailbone securely against the backrest with feet shoulder-width apart. Begin with knees flexed at approximately 90 degrees. Extend the hips and knees to press the sled upward, avoiding knee lockout. Lower the sled under strict control.",
