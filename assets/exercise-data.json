    "equipment": [],
    "exercises": [
        {
            "id": "ex_seated_chest_press",
            "name": "Seated Chest Press",
            "equipment_ids": [
                "eq_seated_chest_press"
            ],
            "primary_muscle_ids": [
                "m_pectoralis_major"
            ],
            "secondary_muscle_ids": [
                "m_anterior_deltoid"
            ],
            "mechanics": "compound",
            "movement_pattern": [
                "push"
            ],
            "description": "Primary focus on the pectoralis major, with synergistic engagement from the anterior deltoid and triceps brachii.",
            "instructions": "Adjust the seat height so the handles align with the mid-chest. Maintain a neutral spine against the backrest with feet firmly planted. Press the handles forward until the elbows are nearly fully extended, avoiding joint lockout. Lower the weight under control during the eccentric phase.",
            "programming": {
                "beginner": {
                    "sets": "2-3",
                    "reps": "10-12",
                    "rpe": "6-7"
                },
                "advanced": {
                    "sets": "4",
                    "reps": "6-10",
                    "rpe": "7-9"
                }
            }
        },
        {
            "id": "ex_lat_pulldown",
            "name": "Lat Pulldown",
            "equipment_ids": [
                "eq_lat_pulldown"
            ],
            "primary_muscle_ids": [
                "m_latissimus_dorsi"
            ],
            "secondary_muscle_ids": [
                "m_trapezius"
            ],
            "mechanics": "compound",
            "movement_pattern": [
                "pull"
            ],
            "description": "Primary engagement of the latissimus dorsi and upper back musculature.",
            "instructions": "Secure your thighs under the knee pads. Grasp the bar with a pronated grip slightly wider than shoulder-width. Initiate the pull by depressing the scapulae, then drive the elbows down to bring the bar toward the upper chest. Avoid excessive lumbar extension or shrugging. Return the bar to the starting position with a controlled eccentric tempo.",
            "programming": {
                "beginner": {
                    "sets": "2-3",
                    "reps": "10-12",
                    "rpe": "6-7"
                },
                "advanced": {
                    "sets": "4",
                    "reps": "6-10",
                    "rpe": "7-9"
                }
            }
        },
        {
            "id": "ex_seated_row",
            "name": "Seated Row",
            "equipment_ids": [
                "eq_seated_row"
            ],
            "primary_muscle_ids": [
                "m_latissimus_dorsi"
            ],
            "secondary_muscle_ids": [
                "m_rhomboids",
                "m_trapezius"
            ],
            "mechanics": "compound",
            "movement_pattern": [
                "pull"
            ],
            "description": "Targets the latissimus dorsi, rhomboids, and middle-to-lower trapezius.",
            "instructions": "Adjust the seat so the chest pad is at sternum level. Maintain a stabilized torso and pull the handles toward the lower chest or abdomen. Focus on maximal scapular retraction at the peak of the concentric phase. Extend the arms slowly during the eccentric phase.",
            "programming": {
                "beginner": {
                    "sets": "2-3",
                    "reps": "10-12",
                    "rpe": "6-7"
                },
                "advanced": {
                    "sets": "4",
                    "reps": "8-12",
                    "rpe": "7-9"
                }
            }
        },
        {
            "id": "ex_high_row",
            "name": "High Row",
            "equipment_ids": [
                "eq_high_row"
            ],
            "primary_muscle_ids": [
                "m_rhomboids",
                "m_posterior_deltoid"
            ],
            "secondary_muscle_ids": [
                "m_trapezius"
            ],
            "mechanics": "compound",
            "movement_pattern": [
                "pull"
            ],
            "description": "Emphasizes upper back thickness, specifically targeting the posterior deltoids and rhomboids.",
            "instructions": "Utilize a wide grip with the chest elevated against the pad. Drive the elbows back and outward, pulling the handles toward the upper chest. Pause briefly at peak contraction before performing a controlled eccentric return.",
            "programming": {
                "beginner": {
                    "sets": "2-3",
                    "reps": "10",
                    "rpe": "6-7"
                },
                "advanced": {
                    "sets": "4",
                    "reps": "8-12",
                    "rpe": "7-9"
                }
            }
        },
        {
            "id": "ex_assisted_pullup",
            "name": "Assisted Pull-Up",
            "equipment_ids": [
                "eq_assisted_pullup"
            ],
            "primary_muscle_ids": [
                "m_latissimus_dorsi"
            ],
            "secondary_muscle_ids": [
                "m_teres_major"
            ],
            "mechanics": "compound",
            "movement_pattern": [
                "pull"
            ],
            "description": "Foundational movement for developing latissimus dorsi strength and overall vertical pulling mechanics.",
            "instructions": "Select the appropriate counterbalance weight. Kneel or step onto the platform, engage the core, and elevate the chest. Initiate the pull by driving the elbows down and back. Lower your body with a controlled eccentric tempo.",
            "programming": {
                "beginner": {
                    "sets": "2-3",
                    "reps": "6-10",
                    "rpe": "6-7"
                },
                "advanced": {
                    "sets": "4",
                    "reps": "8-12",
                    "rpe": "7-9"
                }
            }
